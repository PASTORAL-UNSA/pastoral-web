---
import calendarEvents from "../data/CalendarEvents";
import type { CalendarEvent } from "../interfaces/CalendarEvent";
import PinIcon from "../icons/Pin.astro";
import ClockIcon from "../icons/Clock.astro";

const today = new Date().toISOString().split("T")[0];
const uniqueUpcomingEvents = Array.from(
  new Map(
    calendarEvents
      .filter((evento) => evento.start >= today)
      .map((evento) => [evento.largeTitle, evento]),
  ).values(),
);

const uniqueEventsFallback = Array.from(
  new Map(calendarEvents.map((evento) => [evento.largeTitle, evento])).values(),
);

const featuredSource =
  uniqueUpcomingEvents.length > 0 ? uniqueUpcomingEvents : uniqueEventsFallback;

const featuredEvents = [...featuredSource]
  .sort((a, b) => String(a.start).localeCompare(String(b.start)))
  .slice(0, 3)
  .map((evento, index) => {
    const startDate = new Date(`${evento.start}T00:00:00`);
    const day = Number.isNaN(startDate.getTime())
      ? "--"
      : String(startDate.getDate()).padStart(2, "0");
    const month = Number.isNaN(startDate.getTime())
      ? "MES"
      : startDate
          .toLocaleDateString("es-PE", { month: "short" })
          .replace(".", "")
          .toUpperCase();

    const description = String(evento.description);
    const timeMatch = description.match(
      /(\d{1,2}:\d{2}(?:\s*[ap]\.m\.)?[^,.;]*)/i,
    );
    const timeLabel = timeMatch?.[1]?.trim() ?? description;

    const defaultStatusByIndex =
      index === 0
        ? "ULTIMOS_CUPOS"
        : index === 1
          ? "INSCRIPCION_ABIERTA"
          : "CUPOS_DISPONIBLES";

    const normalizedStatus = String(
      (evento as CalendarEvent & { status?: string }).status ?? defaultStatusByIndex,
    )
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^A-Za-z0-9]+/g, "_")
      .replace(/^_+|_+$/g, "")
      .toUpperCase();

    return {
      ...evento,
      day,
      month,
      timeLabel,
      placeLabel: "Campus UNSA",
      status: normalizedStatus,
    };
  });

const statusLabelMap: Record<string, string> = {
  ULTIMOS_CUPOS: "ULTIMOS CUPOS",
  INSCRIPCION_ABIERTA: "INSCRIPCION ABIERTA",
  CUPOS_DISPONIBLES: "CUPOS DISPONIBLES",
  AGOTADO: "AGOTADO",
  PROXIMAMENTE: "PROXIMAMENTE",
};

const statusClassMap: Record<string, string> = {
  ULTIMOS_CUPOS: "bg-red-600 text-white",
  INSCRIPCION_ABIERTA: "bg-cyan-500 text-white",
  CUPOS_DISPONIBLES: "bg-teal-500 text-white",
  AGOTADO: "bg-slate-700 text-white",
  PROXIMAMENTE: "bg-slate-300 text-slate-900",
};

const getStatusLabel = (status: string) => statusLabelMap[status] ?? "PROXIMAMENTE";

const getStatusClass = (status: string) =>
  statusClassMap[status] ?? statusClassMap.PROXIMAMENTE;
---

<section id="calendario" class="w-full bg-cyan-50/10 px-3 py-12 md:px-6 md:py-16 lg:px-10 lg:py-16">
  <div class="mx-auto mt-8 w-full max-w-4xl md:mt-12 lg:mt-14">
    <div class="space-y-4">
      <header class="text-center">
        <h3 class="text-3xl font-bold tracking-tight text-cyan-800">
          Próximos Eventos
        </h3>
        <p class="mt-2 text-sm text-cyan-900/70">
          No te quedes fuera, los cupos vuelan.
        </p>
      </header>

    <ul class="space-y-4 md:space-y-5">
      {
        featuredEvents.map((evento) => (
          <li class="relative overflow-hidden rounded-3xl border border-cyan-100 bg-white p-4 shadow-[0_10px_30px_rgba(8,47,73,0.12)] md:p-5">
            <span
              class={`absolute right-0 top-0 rounded-bl-2xl px-3 py-1 text-[10px] font-semibold tracking-wide ${getStatusClass(evento.status)}`}
            >
              {getStatusLabel(evento.status)}
            </span>

            <div class="flex gap-3 sm:gap-4">
              <div class="flex min-w-[64px] flex-col items-center justify-center rounded-2xl bg-amber-100 px-2.5 py-2 text-cyan-900 sm:min-w-[68px] sm:px-3">
                <span class="text-2xl font-extrabold leading-none">
                  {evento.day}
                </span>
                <span class="text-xs font-semibold tracking-wide">
                  {evento.month}
                </span>
              </div>

              <div class="min-w-0 flex-1 pr-10 pt-5 sm:pr-8">
                <h4 class="text-[0.98rem] font-semibold leading-tight text-cyan-950 sm:text-base">
                  {evento.largeTitle}
                </h4>
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-800">
                <ClockIcon class="mr-1.5 size-3.5" aria-hidden="true" />
                {evento.timeLabel} hrs
              </span>
              <span class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-800">
                <PinIcon class="mr-1.5 size-3.5" aria-hidden="true" />
                {evento.placeLabel}
              </span>
            </div>
          </li>
        ))
      }
    </ul>


    </div>
  </div>
</section>
