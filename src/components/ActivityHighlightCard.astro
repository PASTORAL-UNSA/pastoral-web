---
import BookIcon from "../icons/Book.astro";
import HeartIcon from "../icons/Heart.astro";
import BulbIcon from "../icons/Bulb.astro";

interface Props {
  title: string;
  description: string;
  icon: "book" | "heart" | "bulb";
  bgClass: string;
  textClass: string;
  buttonClass: string;
  badgeClass: string;
  blobClassA: string;
  blobClassB: string;
}

const {
  title,
  description,
  icon,
  bgClass,
  textClass,
  buttonClass,
  badgeClass,
  blobClassA,
  blobClassB,
} = Astro.props;
---

<article class:list={["relative overflow-hidden rounded-[1.75rem] p-5 sm:p-6 shadow-[0_14px_36px_rgba(6,32,57,0.16)]", bgClass, textClass]}>
  <div class:list={["pointer-events-none absolute -right-10 -top-10 h-36 w-36 rounded-full opacity-70", blobClassA]}></div>
  <div class:list={["pointer-events-none absolute -bottom-14 left-[-1.75rem] h-32 w-32 rounded-full opacity-70", blobClassB]}></div>

  <div class="relative z-10 flex items-start justify-center gap-4">
    <div class:list={["inline-flex size-20 p-2 items-center justify-center rounded-full border border-white/35 shadow-sm", badgeClass]}>
      {
        (() => {
          switch (icon) {
            case "book":
              return <BookIcon class="size-20" />;
            case "heart":
              return <HeartIcon class="size-20" />;
            default:
              return <BulbIcon class="size-20" />;
          }
        })()
      }
    </div>
  </div>

  <h3 class="relative z-10 mt-5 text-2xl font-extrabold leading-tight sm:text-[1.75rem]">{title}</h3>
  <p class="relative z-10 mt-2 max-w-[22ch] font-medium leading-relaxed opacity-90">{description}</p>

  <button
    type="button"
    class:list={[
      "relative z-10 mt-5 inline-flex min-h-10 items-center rounded-full px-4 py-2 text-sm font-semibold transition hover:-translate-y-px",
      buttonClass,
    ]}
  >
    Ver detalles
  </button>
</article>
