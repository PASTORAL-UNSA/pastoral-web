---
import Starts from "../icons/mountain/Starts.astro";
import Paramo from "../icons/mountain/Paramo.astro";
import Mountain from "../icons/mountain/Mountain.astro";
import Moon from "../icons/mountain/Moon.astro";
import Cloud from "../icons/mountain/Cloud.astro";
import WhatsAppIcon from "../icons/WhatsApp.astro";
---

<div id="contacto" class="pt-60 bg-cyan-500/10"></div>
<section class="w-full pb-8 relative min-h-80 bg-cyan-500/10">
  <div class="text-center items-center flex flex-col px-4">
    <h2 class="-mt-28 text-4xl text-cyan-900 font-bold tracking-tighter md:text-5xl">
      Únete a Nuestra Comunidad
    </h2>
    <p class="text-cyan-50 mt-32  max-w-[600px] text-muted-foreground md:text-xl">
      Conéctate con otros estudiantes, comparte tu fe y mantente informado sobre
      nuestras actividades.
    </p>
    <button class="mt-8 transition duration-150 ease-[cubic-bezier(.56,.44,0,1.81)] hover:ease-in hover:shadow-md hover:scale-95 flex flex-row items-center text-white bg-gradient-to-r from-green-400 via-green-500 to-green-600 hover:bg-gradient-to-br focus:ring-1 focus:outline-none focus:ring-green-300 shadow-lg shadow-green-500/50 font-medium rounded-lg text-sm px-5 py-2.5 text-center mb-2">
      <span class="mr-2"> Unirse al Grupo de WhatsApp </span>
      <WhatsAppIcon className="size-5" />
    </button>
  </div>
  <div class="absolute top-0 left-0 right-0 bottom-0 -z-10">
    <Starts class="absolute -top-20 right-0 h-28 w-full" />
    <Moon class="absolute size-14 right-4 -top-10" />
    <Cloud class="absolute -top-4 right-0 h-28" />
    <Mountain class="absolute bottom-20 left-0 right-0" />
    <Paramo class="absolute -bottom-1 right-0" />
  </div>
</section>
