---
import MenuIcon from "../icons/Menu.astro";
import logoPastoral from "../assets/logo_pastoral.png";
import { Image } from "astro:assets";
---

<!-- // TODO: REFACTOR CICLOMATIC COMPLEXITY!!! --><!-- // FIXME: REFACTOR CICLOMATIC COMPLEXITY!!! -->
<header
  id="header"
  class="fixed top-0 right-0 left-0 z-20 border-b border-slate-200 bg-white/90 px-4 py-2 backdrop-blur-sm"
>
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between">
    <div class="size-9" aria-hidden="true"></div>

    <a href="/" class="flex justify-center">
      <Image
        src={logoPastoral}
        alt="Pastoral Universitaria UNSA"
        class="h-auto w-28 object-cover sm:w-36"
      />
    </a>

    <button
      id="btnMenu"
      type="button"
      class="inline-flex size-9 items-center justify-center rounded-full text-slate-800 transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-300"
    >
      <span class="sr-only">Abrir menu principal</span>
      <MenuIcon />
    </button>
  </div>
</header>

<div
  id="mobileMenuContainer"
  class="hidden h-full w-full fixed items-center content-center top-0 left-0 bg-slate-400/80 backdrop-blur-sm z-50"
>
  <div
    id="mobileMenu"
    class="w-3/4 md:block rounded mx-auto bg-slate-50 py-2"
    id="navbar-solid-bg"
  >
    <ul class="flex flex-col font-medium rounded bg-slate-10">
      <!-- TODO: Agregar estado activo -->
      <!-- <li>
        <a href="/#inicio" class="block py-2 px-3 md:p-0 text-white bg-blue-700 rounded md:bg-transparent md:text-blue-700 md:dark:text-blue-500 dark:bg-blue-600 md:dark:bg-transparent" aria-current="page">Inicio</a>
      </li> -->
      <li>
        <a href="/#inicio" class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >🏡 Inicio</a
        >
      </li>
      <li>
        <a
          href="/#nosotros"
          class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >📖 Sobre Nosotros</a
        >
      </li>
      <li>
        <a
          href="/#actividades"
          class="block py-2 px-4 md:p-0 text-gray-900 rounded">🦾 Actividades</a
        >
      </li>
      <li>
        <a href="/#posts" class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >📚 Noticias</a
        >
      </li>
      <li>
        <a href="/#galeria" class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >🎉 Vivencias</a
        >
      </li>
      <li>
        <a
          href="/#testimonios"
          class="block py-2 px-4 md:p-0 text-gray-900 rounded">🎙️ Testimonios</a
        >
      </li>
      <!-- <li>
        <a href="/#equipo" class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >👥 Equipo</a
        >
      </li> -->
      <li>
        <a href="/#faqs" class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >❔ Preguntas</a
        >
      </li>
      <li>
        <a
          href="/#contacto"
          class="block py-2 px-4 md:p-0 text-gray-900 rounded">🤳🏻 Contacto</a
        >
      </li>
    </ul>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const mobileMenuContainer = document.getElementById("mobileMenuContainer");
  const mobileMenu = document.getElementById("mobileMenu");
  const btnMenu = document.getElementById("btnMenu");

  mobileMenuContainer?.addEventListener("click", () => {
    var tl = gsap.timeline();
    tl.to(mobileMenuContainer, { opacity: 0, display: "none", duration: 0.3 });
    tl.to(mobileMenu, { y: 50, duration: 0.3 }, 0);
  });

  btnMenu?.addEventListener("click", () => {
    var tl = gsap.timeline();
    tl.to(mobileMenuContainer, { opacity: 1, display: "block", duration: 0.3 });
    tl.to(mobileMenu, { y: 0, duration: 0.3 }, 0);
  });
</script>
