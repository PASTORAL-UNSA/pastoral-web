---
import WhatsAppButton from "./WhatsAppButton.astro";
---

<div id="inicio" class="pt-[53px]"></div>
<section class="relative w-full lg:max-w-7xl lg:rounded-2xl">
  <div class="hero-visual absolute inset-0 -z-10 rounded-b-3xl"></div>

  <div class="mx-auto grid min-h-[31rem] items-center pt-10 sm:px-6 sm:pt-5 lg:grid-cols-[1.15fr_0.85fr] lg:px-10 lg:pb-24 lg:pt-8">
    <div class="mx-auto flex max-w-xl flex-col items-center space-y-5 text-center text-white lg:ml-0">
      <p
        class="inline-flex items-center rounded-full  bg-white/20 backdrop-blur-sm px-4 py-1.5 text-sm font-semibold uppercase tracking-normal text-white/90"
      >
        COMUNIDAD UNIVERSITARIA
      </p>
      <h1 class="text-[2.15rem] font-extrabold leading-[1.05] text-white sm:text-5xl lg:text-6xl">
        <span>Vive la fe.</span><br />
        <span class="text-[#ffd24a] [text-shadow:0_2px_14px_rgba(9,46,71,0.24)]">Haz amigos en la UNSA.</span>
      </h1>
      <p class="max-w-xl text-base font-medium text-white/85 md:text-lg">
        Conecta, crece y encuentra tu lugar.
      </p>

      <div class="flex flex-wrap items-center justify-center text-gray-600">
        <WhatsAppButton
          class="inline-flex min-h-12 items-center justify-center rounded-3xl border border-[#14243a1f] bg-[#ffd24a] px-12 py-2 text-base font-bold shadow-[0_12px_30px_rgba(11,39,62,0.24)] transition hover:-translate-y-px hover:bg-[#ffd145]"
        />
      </div>
    </div>

    <div
      class="relative -mb-20 mx-auto grid w-[min(92%,29rem)] grid-cols-3 px-2 overflow-hidden rounded-[1.25rem] bg-white shadow-[0_16px_36px_rgba(10,34,55,0.22)] lg:absolute lg:bottom-0 lg:left-10 lg:mt-0 lg:w-[min(29rem,calc(100%-5rem))] lg:translate-y-[42%]"
      aria-label="Impacto de la comunidad"
    >
      <article class="px-[0.5rem] pb-[0.95rem] pt-[1.08rem] text-center">
        <p class="font-bold  text-cyan-600 tracking-tighter">+500</p>
        <p class="tracking-wide text-gray-500">JÓVENES</p>
      </article>
      <article class="px-[0.5rem] pb-[0.95rem] pt-[1.08rem] text-center">
        <p class="font-bold  text-cyan-600 tracking-tighter">10</p>
        <p class="tracking-wide text-gray-500">GRUPOS</p>
      </article>
      <article class="px-[0.5rem] pb-[0.95rem] pt-[1.08rem] text-center">
        <p class="font-bold  text-cyan-600 tracking-tighter">1</p>
        <p class="tracking-wide text-gray-500">FAMILIA</p>
      </article>
    </div>
  </div>
</section>

<style>
  .hero-visual {
    background-color: #0d98b0;
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.2) 1.8px, transparent 1.8px),
      linear-gradient(150deg, #0f96af 0%, #0aa0bc 52%, #0b8ba4 100%);
    background-size: 22px 22px, cover;
    background-position: 0 0, center;
  }
</style>
