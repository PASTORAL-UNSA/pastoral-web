---
import members from "../data/Members";
---

<div id="equipo" class="pt-20"></div>
<section class="w-full pb-8 md:py-24 lg:py-8 bg-cyan-50/10 lg:max-w-7xl">
  <div class="container px-4 md:px-6">
    <h2
      class="text-3xl font-medium tracking-tighter sm:text-4xl md:text-5xl mb-8 text-cyan-900"
    >
      Nuestro Equipo
    </h2>
    <div class="grid gap-4 grid-cols-2 sm:grid-cols-3">
      {
        members.map(({ name, rol, urlImage }) => (
          <div class="border border-gray-350 rounded-lg p-4 bg-white shadow-sm text-center">
            <div class="flex flex-col items-center space-y-4">
              <img
                src={urlImage}
                alt=""
                class="size-24 rounded-full bg-slate-500 object-cover"
              />
              <h1 class="text-md font-semibold text-gray-700">{name}</h1>
            </div>
            <div class="text-center">
              <p class="mt-2 text-gray-400 text-sm">{rol}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
