---
import posts from "../data/Posts";
import PostCard from "./PostCard.astro";
---
<div id="posts" class="pt-20"></div>

<section class="w-full pb-8 md:py-24 lg:py-8 bg-cyan-50/10 lg:max-w-7xl">
  <div class="container px-4 md:px-6">
    <h2 class="text-3xl font-semibold tracking-tighter sm:text-4xl md:text-5xl mb-8 text-cyan-900">
      Noticias
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</section>
