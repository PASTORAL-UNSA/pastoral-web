---
import posts from "../data/Posts";
import PostCard from "./PostCard.astro";
---
<div id="posts" class="pt-20"></div>

<section class="w-full bg-slate-50 py-12 md:py-16">
  <div class="mx-auto w-full max-w-3xl px-4 md:px-6">
    <h2 class="mb-8 text-left text-2xl font-semibold tracking-tight text-cyan-700 sm:text-4xl">
      Últimas Noticias
    </h2>
    <div class="space-y-8">
      {posts.map((post, index) => <PostCard post={post} index={index} />)}
    </div>
    <div class="mt-10 flex justify-center">
      <a
        href="/news"
        class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100"
      >
        Ver todas las noticias
      </a>
    </div>
  </div>
</section>
