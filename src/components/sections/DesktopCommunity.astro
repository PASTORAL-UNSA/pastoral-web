---
import { testimonialList } from "../../data/Testimonials";
---

<section id="testimonios" class="w-full py-12 md:py-16 lg:py-20">
  <div class="mx-auto w-full max-w-7xl px-4 md:px-6 lg:px-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-cyan-700">
        Nuestra Comunidad
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-cyan-900 sm:text-4xl lg:text-5xl">
        Historias que inspiran
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-cyan-900/75 sm:text-base">
        Estudiantes de distintas carreras comparten como la pastoral fortalece su vida universitaria y su fe.
      </p>
    </div>

    <div class="mt-10 grid gap-6 lg:mt-12 lg:grid-cols-3">
      {
        testimonialList.slice(0, 3).map((item, index) => {
          const highlight = index === 1;
          const initial = item.name.trim().charAt(0).toUpperCase();
          return (
            <article
              class:list={[
                "relative flex h-full flex-col rounded-[2rem] border px-6 pb-7 pt-8 text-center",
                highlight
                  ? "-translate-y-2 border-cyan-900 bg-cyan-900 text-cyan-50 shadow-[0_24px_50px_rgba(8,47,73,0.32)]"
                  : "border-cyan-100 bg-white text-slate-700 shadow-[0_16px_34px_rgba(8,47,73,0.12)]",
              ]}
            >
              <div
                class:list={[
                  "mx-auto flex size-16 items-center justify-center overflow-hidden rounded-full border-4",
                  highlight
                    ? "border-cyan-700 bg-cyan-100 text-cyan-900"
                    : "border-cyan-200 bg-cyan-700 text-white",
                ]}
                aria-hidden="true"
              >
                {item.urlImage ? (
                  <img
                    src={item.urlImage}
                    alt={`Foto de ${item.name}`}
                    class="size-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  initial
                )}
              </div>

              <p class:list={["mt-5 text-base italic leading-relaxed", highlight ? "text-cyan-50/90" : "text-slate-600"]}>
                "{item.description}"
              </p>

              <div class="mt-6 border-t border-current/15 pt-4">
                <h3 class="text-lg font-semibold">{item.name}</h3>
                <p class:list={["mt-1 text-sm", highlight ? "text-cyan-100/80" : "text-cyan-900/80"]}>
                  {item.role ?? "Estudiante"}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
