---
import posts from "../../data/Posts";
import { FAQs } from "../../data/FAQs";
import RowColapseIcon from "../../icons/RowColapse.astro";
---

<section id="posts" class="w-full bg-slate-50 py-12 md:py-16 lg:py-20">
  <div class="mx-auto grid w-full max-w-7xl gap-8 px-4 md:px-6 lg:grid-cols-12 lg:gap-10 lg:px-10">
    <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_38px_rgba(8,47,73,0.1)] lg:col-span-7 lg:p-8">
      <div class="flex items-end justify-between gap-3">
        <h2 class="text-2xl font-semibold tracking-tight text-cyan-900 sm:text-3xl">
          Últimas Noticias
        </h2>
        <a href="/news" class="text-sm font-medium text-cyan-700 transition hover:text-cyan-900">
          Ver todas
        </a>
      </div>

      <div class="mt-6 space-y-4">
        {
          posts.slice(0, 2).map((post) => (
            <a
              href={post.urlPost}
              class="group block rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-cyan-300 hover:bg-white"
            >
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-amber-500">
                {post.categories[0] ?? "Noticia"}
              </p>
              <h3 class="mt-2 text-lg font-semibold leading-snug text-slate-800 group-hover:text-cyan-900">
                {post.title}
              </h3>
              <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-600">
                {post.description}
              </p>
            </a>
          ))
        }
      </div>
    </article>

    <article id="faqs" class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_38px_rgba(8,47,73,0.1)] lg:col-span-5 lg:p-8">
      <h2 class="text-2xl font-semibold tracking-tight text-cyan-900 sm:text-3xl">
        Dudas Rápidas
      </h2>
      <div class="mt-5 divide-y divide-slate-200">
        {
          FAQs.slice(0, 4).map((faq) => (
            <details class="group py-4" open={false}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-medium text-slate-700">
                <span>{faq.question}</span>
                <RowColapseIcon class="size-3 shrink-0 text-cyan-700 transition group-open:rotate-180" />
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </article>
  </div>
</section>
