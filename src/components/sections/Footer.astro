---
import MailIcon from "../../icons/Mail.astro";
import PhoneIcon from "../../icons/Phone.astro";
import PinIcon from "../../icons/Pin.astro";
import FacebookIcon from "../../icons/mountain/Facebook.astro";
import InstagramIcon from "../../icons/mountain/Instagram.astro";
import TikTokIcon from "../../icons/mountain/TikTok.astro";
---

<footer class="w-full bg-[#2574b0] text-gray-100/95 py-12">
  <div class="container px-4 md:px-6 mx-auto lg:max-w-7xl">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div class="space-y-4">
        <h2 class="text-3xl font-bold">Pastoral Universitaria</h2>
        <p class="max-w-sm text-sm text-gray-100">
          Acompañando tu camino de fe en la vida universitaria.
        </p>
        <div class="flex flex-row items-center space-x-3">
          <a target="_blank">
            <FacebookIcon class="size-5" />
          </a>
          <a
            class="bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] p-[3px] rounded-md"
            target="_blank"
          >
            <InstagramIcon class="size-4" />
          </a>
          <a target="_blank">
            <TikTokIcon class="size-5" />
          </a>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="text-lg font-semibold">Contacto</h3>
        <ul class="space-y-2">
          <li class="flex items-start space-x-2">
            <MailIcon class="size-5" />
            <span class="break-all">pastoral@pastoralunsa.org</span>
          </li>
          <li class="flex items-center space-x-2">
            <PhoneIcon class="size-5" />
            <span>+51 902182088</span>
          </li>
          <li class="flex items-start space-x-2">
            <PinIcon class="size-5" />
            <span class="leading-snug">Calle Universidad 123, Ciudad Universitaria</span>
          </li>
        </ul>
      </div>
   <!--   
      <div class="space-y-4">
        <h3 class="text-lg font-semibold">Enlaces Rápidos</h3>
        <ul class="space-y-2">
          <li>
            <a href="/about" class="hover:text-white transition-colors">
              Sobre Nosotros
            </a>
          </li>
          <li>
            <a href="/activities" class="hover:text-white transition-colors">
              Actividades
            </a>
          </li>
          <li>
            <a href="/blog" class="hover:text-white transition-colors">
              Blog
            </a>
          </li>
          <li>
            <a href="/contact" class="hover:text-white transition-colors">
              Contáctanos
            </a>
          </li>
        </ul>
      </div>
  -->
    </div>
      <div class="mt-8 border-t border-gray-100 pt-8 text-center text-sm text-gray-200">
      <p>
        &copy; {new Date().getFullYear()} Pastoral Universitaria. Todos los derechos
        reservados.
      </p>
      <!-- 
        <div class="mt-4 flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
        <a href="/privacy" class="hover:text-white transition-colors">
          Política de Privacidad
        </a>
        <a href="/terms" class="hover:text-white transition-colors">
          Términos de Uso
        </a>
      </div>
      -->
    </div>
  </div>
</footer>
