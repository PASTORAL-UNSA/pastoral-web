---
import MenuIcon from "../../icons/Menu.astro";
import logoPastoral from "../../assets/logo_pastoral.png";
import { Image } from "astro:assets";
import WhatsAppButton from "../WhatsAppButton.astro";
---

<header
  id="header"
  class="fixed inset-x-0 top-0 z-40 w-full border-b border-slate-200 bg-white/95 px-4 py-2 backdrop-blur-sm lg:px-6"
>
  <div class="mx-auto grid w-full max-w-7xl grid-cols-[1fr_auto_1fr] items-center gap-4 lg:grid-cols-[auto_1fr_auto] lg:gap-8">
    <div class="size-9 lg:hidden" aria-hidden="true"></div>

    <a href="/" class="flex justify-center justify-self-center lg:justify-self-start">
      <Image
        src={logoPastoral}
        alt="Pastoral Universitaria UNSA"
        class="h-auto w-28 object-cover sm:w-36 lg:w-[9.5rem]"
      />
    </a>

    <nav class="hidden justify-self-center lg:flex" aria-label="Navegacion principal">
      <ul class="flex items-center gap-7 text-[0.95rem] font-medium text-slate-700">
        <li><a href="/#inicio" class="relative pb-1 transition hover:text-cyan-800">Inicio</a></li>
        <li>
          <a href="/#actividades" class="relative pb-1 text-slate-900 after:absolute after:-bottom-[0.36rem] after:left-0 after:h-0.5 after:w-full after:rounded-full after:bg-cyan-600">Eventos</a>
        </li>
        <li><a href="/#nosotros" class="relative pb-1 transition hover:text-cyan-800">Nosotros</a></li>
        <li><a href="/#galeria" class="relative pb-1 transition hover:text-cyan-800">Galeria</a></li>
        <li><a href="/#contacto" class="relative pb-1 transition hover:text-cyan-800">Contacto</a></li>
      </ul>
    </nav>

    <div class="justify-self-end">
      <div class="hidden items-center gap-7 lg:flex">
        <WhatsAppButton
          label="Unirme"
          showIcon={false}
          class="inline-flex min-h-10 items-center justify-center rounded-full bg-cyan-600 px-6 text-sm font-semibold text-white transition hover:bg-cyan-700"
        />
      </div>

      <button
        id="btnMenu"
        type="button"
        class="inline-flex size-9 items-center justify-center rounded-full text-cyan-700 transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-300 lg:hidden"
      >
        <span class="sr-only">Abrir menu principal</span>
        <MenuIcon />
      </button>
    </div>
  </div>
</header>

<div
  id="mobileMenuContainer"
  class="fixed inset-0 z-50 hidden items-start justify-center overflow-y-auto bg-slate-900/45 p-4 pt-20 backdrop-blur-sm"
>
  <div
    id="mobileMenu"
    class="w-full max-w-sm rounded-2xl bg-slate-50 py-2 shadow-xl"
  >
    <ul class="flex flex-col rounded bg-slate-10 text-sm font-medium">
      <!-- TODO: Agregar estado activo -->
      <!-- <li>
        <a href="/#inicio" class="block py-2 px-3 md:p-0 text-white bg-blue-700 rounded md:bg-transparent md:text-blue-700 md:dark:text-blue-500 dark:bg-blue-600 md:dark:bg-transparent" aria-current="page">Inicio</a>
      </li> -->
      <li>
        <a href="/#inicio" class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100"
          >Inicio</a
        >
      </li>
      <li>
        <a
          href="/#calendario"
          class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100"
          >Calendario</a
        >
      </li>
      <li>
        <a
          href="/#actividades"
          class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100">Actividades</a
        >
      </li>
      <li>
        <a
          href="/#nosotros"
          class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100">Nosotros</a
        >
      </li>
      <li>
        <a href="/#galeria" class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100"
          >Galeria</a
        >
      </li>
      <li>
        <a href="/#posts" class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100"
          >Noticias</a
        >
      </li>
      <li>
        <a
          href="/#testimonios"
          class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100">Testimonios</a
        >
      </li>
      <!-- <li>
        <a href="/#equipo" class="block py-2 px-4 md:p-0 text-gray-900 rounded"
          >👥 Equipo</a
        >
      </li> -->
      <li>
        <a href="/#faqs" class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100"
          >Preguntas</a
        >
      </li>
      <li>
        <a
          href="/#contacto"
          class="block rounded px-4 py-2.5 text-gray-900 transition hover:bg-slate-100">Contacto</a
        >
      </li>
    </ul>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const mobileMenuContainer = document.getElementById("mobileMenuContainer");
  const mobileMenu = document.getElementById("mobileMenu");
  const btnMenu = document.getElementById("btnMenu");

  mobileMenuContainer?.addEventListener("click", () => {
    var tl = gsap.timeline();
    tl.to(mobileMenuContainer, { opacity: 0, display: "none", duration: 0.3 });
    tl.to(mobileMenu, { y: 50, duration: 0.3 }, 0);
  });

  btnMenu?.addEventListener("click", () => {
    var tl = gsap.timeline();
    tl.to(mobileMenuContainer, { opacity: 1, display: "flex", duration: 0.3 });
    tl.to(mobileMenu, { y: 0, duration: 0.3 }, 0);
  });
</script>
