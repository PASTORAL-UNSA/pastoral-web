---
import { testimonialList } from "../../data/Testimonials";
import TestimonialCard from "../TestimonialCard.astro";
---
<div id="testimonios" class="tp-10"></div>
<section class="w-full bg-cyan-50/10 py-12 md:py-16 lg:py-20">
  <div class="mx-auto w-full max-w-7xl px-4 md:px-6 lg:px-10">
    <header class="max-w-2xl mb-10">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-cyan-700">
        Comunidad que acompana
      </p>
      <h2 class="mt-2 text-3xl font-semibold tracking-tight text-cyan-900 sm:text-4xl md:text-5xl">
        Testimonios
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-cyan-900/75 sm:text-base">
        Historias reales de estudiantes que encontraron amistad, fe y apoyo en la Pastoral Universitaria.
      </p>
    </header>

    <div class="mt-16 grid gap-6 sm:mt-10 sm:grid-cols-2 sm:gap-7 lg:mt-12 lg:grid-cols-3 lg:gap-7">
      {
        testimonialList.map((testimonial, index) => (
          <TestimonialCard testimonial={testimonial} index={index} />
        ))
      }
    </div>
  </div>
</section>
