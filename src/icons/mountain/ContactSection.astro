---
import FooterSection from "./Footer.astro";
import Starts from "../icons/Starts.astro";
import Paramo from "../icons/Paramo.astro";
import Mountain from "../icons/Mountain.astro";
import Moon from "../icons/Moon.astro";
import Cloud from "../icons/Cloud.astro";
import WspForm from "./WspForm";
---

<div
  id="contacto"
  class="overflow-hidden h-screen w-full px-4 sticky left-0 right-0 bottom-0 bg-[#3498DB]"
>
  <h1 class="text-4xl font-bold mt-24 text-white">CONTACTANOS!</h1>

  <WspForm client:only="react"/>

  <Starts class="absolute top-50 left-0 right-0 h-28 -z-10" />
  <Moon class="absolute top-52 right-10 size-10 -z-10" />
  <Cloud class="absolute top-44 right-0 h-28 -z-10" />
  <Mountain class="absolute bottom-10 -left-10 -right-10 -z-10" />
  <Paramo class="absolute -bottom-10 left-0 right-0 -z-10" />
  <FooterSection />
</div>
