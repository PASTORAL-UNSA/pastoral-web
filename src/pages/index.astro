---
import MainLayout from "../layouts/Main.astro";

import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import AboutUs from "../components/AboutUs.astro";
import Activities from "../components/Activities.astro";
import ActivityCalendar from "../components/ActivityCalendar.astro";
import Posts from "../components/Posts.astro";
import Testimonials from "../components/Testimonials.astro";
import Footer from "../components/Footer.astro";
import Members from "../components/Members.astro";
import Galery from "../components/Galery.astro";
import FAQ from "../components/FAQ.astro";
import ContactUs from "../components/ContactUs.astro";
---

<MainLayout title="PASTORAL UNSA">
  <Header />
  <div class="lg:flex flex-col items-center">
    <Hero />
    <ActivityCalendar />
    <Activities />
    <AboutUs />
    <Galery />
    <Posts />
    <Testimonials />
    <FAQ />
    <ContactUs />
    <Footer />
  </div>
</MainLayout>
